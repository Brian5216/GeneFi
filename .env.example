# OKX OnchainOS Configuration
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here
OKX_BASE_URL=https://www.okx.com

# Claw (Claude) Model Configuration
CLAW_API_KEY=your_claw_api_key_here
CLAW_OPUS_MODEL=claw-opus-latest
CLAW_SONNET_MODEL=claw-sonnet-latest

# System Configuration
DEMO_MODE=true
EXECUTION_MODE=simulation
EVOLUTION_POPULATION_SIZE=20
EVOLUTION_GENERATIONS=15
MUTATION_RATE=0.15
SELECTION_PRESSURE=0.3
